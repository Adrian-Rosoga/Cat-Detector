# Non-secret runtime defaults for launchers
# This file is loaded by run_cat_detector.bat and detect_coco.bat before secrets.env.

# Default model alias or path
CAT_DETECTOR_MODEL=yolo26n

# Maximum number of snapshot files to keep in the snapshot directory (oldest deleted first)
SNAPSHOT_MAX_FILES=1000

# Minimum seconds between saved snapshots in detect_coco.bat
SNAPSHOT_COOLDOWN=2
